save_wit# =====================================================
# ATBSocialMedia - Root .env example
# =====================================================
# Kopyalayın: cp .env.example .env
# Backend ve Frontend ayrı ayrı da yönetilebilir.

# ---------- Genel ----------
NODE_ENV=development
APP_NAME=ATBSocialMedia
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---------- Veritabanı ----------
DATABASE_URL=postgresql://atb:atb@localhost:5432/atbsocialmedia
REDIS_URL=redis://localhost:6379

# ---------- Google Gemini ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_VISION_MODEL=gemini-1.5-flash

# ---------- WhatsApp (Yöntem A - QR / Baileys) ----------
WA_QR_ENABLED=true
WA_SESSION_PATH=./.wa-sessions

# ---------- WhatsApp (Yöntem B - Resmi Business API) ----------
WA_BUSINESS_ENABLED=false
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_ACCESS_TOKEN=
WA_WEBHOOK_VERIFY_TOKEN=

# ---------- Telegram (kritik bildirim) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- E-posta (kritik bildirim) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ---------- Sosyal Medya (OAuth) ----------
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ---------- Canva Connect API ----------
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://localhost:4000/api/canva/callback
